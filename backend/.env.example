# Copy this to .env and fill in your values.
# Get both from: Supabase dashboard → Project Settings → API

# Your project's public URL
SUPABASE_URL=https://your-project-id.supabase.co

# Service role key — server-side only, NEVER expose to the frontend.
# This is the JWT key starting with eyJ... (not the publishable key)
# It bypasses Row Level Security, which the import script needs.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
